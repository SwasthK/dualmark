{
  "name": "@dualmark/cloudflare",
  "version": "0.5.2",
  "description": "Cloudflare Workers edge adapter for the Dualmark AEO framework. Wraps any upstream Worker and transparently serves markdown to AI bots.",
  "license": "Apache-2.0",
  "author": "Dodo Payments <opensource@dodopayments.com> (https://dodopayments.com)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dodopayments/dualmark.git",
    "directory": "packages/cloudflare"
  },
  "bugs": {
    "url": "https://github.com/dodopayments/dualmark/issues"
  },
  "homepage": "https://github.com/dodopayments/dualmark/tree/main/packages/cloudflare#readme",
  "funding": "https://github.com/sponsors/dodopayments",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@dualmark/core": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250115.0",
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "keywords": [
    "aeo",
    "answer-engine-optimization",
    "cloudflare",
    "cloudflare-workers",
    "workers",
    "edge",
    "ai-agents",
    "ai-search",
    "wrangler",
    "dualmark"
  ],
  "engines": {
    "node": ">=18.18.0"
  }
}
