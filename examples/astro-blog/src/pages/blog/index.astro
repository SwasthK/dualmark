---
import { getCollection } from "astro:content";
const posts = await getCollection("blog");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Blog — Dualmark Example</title>
  </head>
  <body>
    <main>
      <h1>Blog</h1>
      <ul>
        {posts.map((p) => (
          <li>
            <a href={`/blog/${p.id}`}>{p.data.title}</a>
          </li>
        ))}
      </ul>
    </main>
  </body>
</html>
